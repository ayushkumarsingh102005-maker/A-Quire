**/.env.production
**/serviceAccountKey.json

# ── Python ────────────────────────────────────────────────────────────────────
backend/venv/
**/__pycache__/
**/*.pyc
**/*.pyo
**/.pytest_cache/
**/*.egg-info/
**/dist/
**/.eggs/

# ── Node / Frontend ───────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json

# ── Logs / Temp ───────────────────────────────────────────────────────────────
*.log
fix_encoding.py
~$*.docx
